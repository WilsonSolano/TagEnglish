<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#16161A"
    android:padding="12dp">

    <!-- Header: TagEnglish + contador -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TagEnglish"
            android:textColor="#CAFF4D"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textColor="#CAFF4D"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="#252530"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

    <!-- Barra de progreso -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="7dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#CAFF4D"
        android:progressBackgroundTint="#252530" />

    <!-- Palabra principal -->
    <TextView
        android:id="@+id/widget_word"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="---"
        android:textColor="#F5F5F5"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Fonética -->
    <TextView
        android:id="@+id/widget_phonetic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#4A4A5A"
        android:textSize="9sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <!-- Contenedor de significados — addView() funciona directo en LinearLayout -->
    <LinearLayout
        android:id="@+id/widget_usages_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical" />

</LinearLayout>